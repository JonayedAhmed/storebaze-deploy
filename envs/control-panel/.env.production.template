# ============================================================================
# StoreBaze Control Panel (super-admin UI) — PRODUCTION env template
# ============================================================================
# NEXT_PUBLIC_* vars are baked into the client bundle at build time. Set
# them as Variables in the control-panel GitHub repo:
#
#   Settings → Secrets and variables → Actions → Variables
#     - NEXT_PUBLIC_BASE_URL
#     - NEXT_PUBLIC_PLATFORM_NAME
# ============================================================================

NODE_ENV=production

# Backend API the super-admin UI talks to
NEXT_PUBLIC_BASE_URL=https://api.storebaze.com

# Branding shown in the UI
NEXT_PUBLIC_PLATFORM_NAME=StoreBaze
