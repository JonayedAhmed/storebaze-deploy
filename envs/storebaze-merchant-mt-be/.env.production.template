# ============================================================================
# StoreBaze Merchant Backend — PRODUCTION env template
#
# On the server:
#   cp .env.production.template /root/envs/storebaze-merchant-mt-be/.env.production
#   chmod 600 /root/envs/storebaze-merchant-mt-be/.env.production
#   nano  /root/envs/storebaze-merchant-mt-be/.env.production   # fill REPLACE_ME values
#
# NEVER commit the real file. Only this template is checked in.
# ============================================================================

# --- Core --------------------------------------------------------------------
NODE_ENV=production
PORT=5000

# --- Database (MongoDB Atlas) ------------------------------------------------
# NOTE: this is currently still the dev URI — replace with a dedicated prod
# cluster connection string before going live.
MONGODB_URI=REPLACE_ME_mongodb+srv://user:pass@cluster.mongodb.net/storebaze-prod

# --- Auth --------------------------------------------------------------------
# Generate with: openssl rand -hex 48
JWT_SECRET=REPLACE_ME_generate_64_char_random_string
JWT_EXPIRE=7d

# --- URLs (multi-tenant) -----------------------------------------------------
# Per-merchant storefront base. Subdomains attach: ${subdomain}.${STORE_BASE_DOMAIN}
STORE_BASE_DOMAIN=storebaze.com
STORE_FRONTEND_URL=https://storebaze.com

# Used in email templates (links back to platform)
FRONTEND_URL=https://storebaze.com

# Marketing/landing site
PLATFORM_DOMAIN=storebaze.com

# Must be FALSE in production — tenant resolves from subdomain only
ALLOW_STORE_ID_HEADER=false

# --- Stripe (live keys) ------------------------------------------------------
STRIPE_SECRET_KEY=REPLACE_ME_sk_live_xxx
STRIPE_PUBLISHABLE_KEY=REPLACE_ME_pk_live_xxx
# Per-store customer payments
STRIPE_CONNECT_WEBHOOK_SECRET=REPLACE_ME_whsec_connect_xxx
# Subscriptions + theme purchases
STRIPE_PLATFORM_WEBHOOK_SECRET=REPLACE_ME_whsec_platform_xxx

# --- Email (Resend) ----------------------------------------------------------
# Two Resend accounts: one per verified sender domain.
#   • Platform account → storebaze.com (system@storebaze.com)
#   • Merchant account → storebaze.app + every merchant custom domain
#                        registered via resend.domains.create()
# Each account has its own API key + webhook signing secret.
RESEND_PLATFORM_API_KEY=REPLACE_ME_re_platform_xxx
RESEND_MERCHANT_API_KEY=REPLACE_ME_re_merchant_xxx
RESEND_PLATFORM_WEBHOOK_SECRET=REPLACE_ME_whsec_resend_platform_xxx
RESEND_MERCHANT_WEBHOOK_SECRET=REPLACE_ME_whsec_resend_merchant_xxx
STOREBAZE_FROM_EMAIL=system@storebaze.com
# Free / no-custom-domain merchants send from this domain (legal isolation
# from platform brand).
MERCHANT_FROM_DOMAIN=storebaze.app
CONTACT_EMAIL=support@storebaze.com

# Email deliverability thresholds (optional — defaults shown)
EMAIL_BOUNCE_RATE_THRESHOLD_PERCENT=8
EMAIL_BOUNCE_WINDOW_EMAILS=200
EMAIL_COMPLAINT_RATE_THRESHOLD_PERCENT=0.3
EMAIL_COMPLAINT_WINDOW_EMAILS=500

# --- Dropship encryption (REQUIRED — must be 64 hex chars / 32 bytes) -------
# Generate with: openssl rand -hex 32
DROPSHIP_ENCRYPTION_KEY=REPLACE_ME_64_hex_chars

# --- Cron / reconciliation (optional — defaults shown) ----------------------
RECONCILE_CRON_SCHEDULE=*/15 * * * *
RECONCILE_MIN_AGE_MS=600000
RECONCILE_MAX_AGE_MS=604800000
DROPSHIP_LOCK_MAX_AGE_MS=900000

# --- EventLog retention (days; default 365) ---------------------------------
EVENT_LOG_TTL_DAYS=365

# --- AI Section Generator (PHASE-9 / AI-AUTOPILOT) --------------------------
ANTHROPIC_API_KEY=REPLACE_ME_sk-ant-api03-xxx
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5

# --- DoorDash Delivery (Phase 22) -------------------------------------------
# Commented out — DoorDash is not enabled in production yet. Uncomment and
# fill in real credentials when launching the delivery feature.
# DOORDASH_DEVELOPER_ID=REPLACE_ME
# DOORDASH_KEY_ID=REPLACE_ME
# DOORDASH_SIGNING_SECRET=REPLACE_ME
# DOORDASH_ENVIRONMENT=production
# DOORDASH_MARKUP_PERCENT=15
