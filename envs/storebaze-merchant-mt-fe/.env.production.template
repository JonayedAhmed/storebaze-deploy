# ============================================================================
# StoreBaze Merchant Frontend (multi-tenant) — PRODUCTION env template
# ============================================================================
# Any var prefixed NEXT_PUBLIC_ is baked into the CLIENT BUNDLE at
# `next build` time. These must ALSO be set as GitHub Actions variables in
# the storebaze-merchant-mt-fe repo so the build embeds them:
#
#   Settings → Secrets and variables → Actions
#     Variables:  NEXT_PUBLIC_BASE_URL
#                 NEXT_PUBLIC_PLATFORM_DOMAIN
#                 NEXT_PUBLIC_LANDING_PORT  (leave blank in prod)
#     Secrets:    NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#
# Setting them only at runtime here is NOT enough for the inlined values.
# Runtime values below are used by the Node server (server-side calls).
# ============================================================================

NODE_ENV=production

# --- Backend API ------------------------------------------------------------
# Server-side calls (Node runtime inside container) — internal Docker network.
# Resolves to the `backend` compose service.
BACKEND_URL=http://backend:5000
# Browser-exposed base — public HTTPS endpoint (must match what the bundle
# was built with via GitHub Actions variable).
NEXT_PUBLIC_BASE_URL=https://api.storebaze.com

# --- Multi-tenant routing ---------------------------------------------------
# Subdomains of this domain resolve to merchant stores.
NEXT_PUBLIC_PLATFORM_DOMAIN=storebaze.com
# Empty in production — landing has its own apex domain.
NEXT_PUBLIC_LANDING_PORT=

# Dev-only: leave empty in production
NEXT_PUBLIC_STORE_ID=

# --- Auth (NextAuth) --------------------------------------------------------
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_ME_generate_random_32_byte_hex
NEXTAUTH_URL=https://storebaze.com

# --- Stripe (publishable key only — secret stays in backend) ----------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_ME_pk_live_xxx

# --- Section preview token (required in production) -------------------------
# Generate with: openssl rand -hex 32
SECTION_PREVIEW_TOKEN=REPLACE_ME_random_string
