# ============================================================================
# StoreBaze Landing — PRODUCTION env template
# ============================================================================
# NEXT_PUBLIC_* vars are baked into the client bundle at build time. Set
# them as Variables in the storebaze-landing GitHub repo:
#
#   Settings → Secrets and variables → Actions → Variables
#     - NEXT_PUBLIC_API_URL
#     - NEXT_PUBLIC_STOREFRONT_BASE
#     - NEXT_PUBLIC_PLATFORM_DOMAIN
# ============================================================================

NODE_ENV=production

# Public API endpoint (browser → backend through Caddy)
NEXT_PUBLIC_API_URL=https://api.storebaze.com/api

# Where to send users after signup to preview their new store
NEXT_PUBLIC_STOREFRONT_BASE=https://storebaze.com

# Platform domain (used for subdomain validation + copy)
NEXT_PUBLIC_PLATFORM_DOMAIN=storebaze.com
