# ============================================================================
# StoreBaze production Caddyfile
#
# Upstreams (compose service names, NOT container names):
#   backend          → Express API on :5000
#   merchant-fe      → Next.js multi-tenant FE on :3000
#   landing          → Next.js marketing site on :3000
#   control-panel    → Next.js super-admin UI on :3000
#
# Public routing:
#   storebaze.com, www.storebaze.com   → landing
#   api.storebaze.com                  → backend
#   control.storebaze.com              → control-panel
#   *.storebaze.com (any other)        → merchant-fe
#   {merchant_custom_domain} (Phase 8) → merchant-fe (on-demand TLS, HTTP-01,
#                                         gated by backend ask endpoint)
#
# TLS:
#   storebaze.com hosts use DNS-01 via Cloudflare (global setting below)
#   — we own the zone, and DNS-01 works for both apex and the *.storebaze.com
#   wildcard regardless of CF proxy state.
#
#   Merchant custom domains use on-demand TLS (HTTP-01), because we don't
#   control the merchant's DNS zone. Caddy asks the backend before issuing a
#   cert (see on_demand_tls.ask below) — this is what stops attackers from
#   pointing random hostnames at us and burning Let's Encrypt rate limits.
#   Requires port 80 to stay open on the droplet for HTTP-01 challenges.
#
#   Requires CLOUDFLARE_API_TOKEN in /root/.env on the server
#   (Zone:Read + DNS:Edit, scoped to storebaze.com) for the DNS-01 path.
# ============================================================================

{
    # Global options. Used by Let's Encrypt to send cert-expiry warnings
    # (Caddy auto-renews; this is just a safety-net contact).
    email storebazehq@gmail.com

    # DNS-01 challenge via Cloudflare for storebaze.com hosts (apex +
    # wildcard). Caddy auto-falls back to HTTP-01 for hosts whose zone we
    # don't control — i.e. merchant custom domains served by the :443
    # on-demand block below.
    acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}

    # On-demand TLS gate for merchant custom domains (Phase 8). Caddy calls
    # this endpoint over the internal Docker network before attempting to
    # issue a cert for an unknown SNI. Backend returns 200 only if the host
    # is registered to a verified, feature-enabled merchant.
    on_demand_tls {
        ask http://backend:5000/api/public/domain-allowed
    }

    # Uncomment while testing to avoid Let's Encrypt rate limits:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ---------- Landing (apex + www) --------------------------------------------
storebaze.com, www.storebaze.com {
    encode zstd gzip
    reverse_proxy landing:3000
}

# ---------- Backend API ------------------------------------------------------
api.storebaze.com {
    encode zstd gzip

    # Stripe / DoorDash / Resend webhooks need the *raw* body. Caddy proxies
    # streams unbuffered by default — no changes required.

    reverse_proxy backend:5000

    # Optional: serve /uploads/* directly from disk (skip the Node hop).
    # handle /uploads/* {
    #     root * /uploads
    #     file_server
    # }
}

# ---------- Control panel (super-admin) -------------------------------------
control.storebaze.com {
    encode zstd gzip
    reverse_proxy control-panel:3000
}

# ---------- Merchant frontend (wildcard tenant subdomains) ------------------
# Catch-all for *.storebaze.com that didn't match the named hosts above.
# Must come AFTER all named hosts. DNS-01 is handled globally above.
*.storebaze.com {
    encode zstd gzip
    reverse_proxy merchant-fe:3000
}

# ---------- Merchant custom domains (Phase 8, on-demand TLS) ----------------
# Catches any hostname not matched by the named blocks above. Caddy asks the
# backend whether the host belongs to a verified merchant before issuing a
# cert via HTTP-01 (we don't control merchant DNS, so DNS-01 isn't an option).
# MUST be the last site block.
:443 {
    tls {
        on_demand
    }
    encode zstd gzip
    reverse_proxy merchant-fe:3000
}
